{
  "name": "@sao-lourenco/api",
  "version": "0.1.0",
  "description": "POC de API RESTful para exposição de serviços prestados",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migration:generate": "pnpm exec tsx $(node -e \"console.log(require.resolve('typeorm/cli.js'))\") migration:generate ./src/shared/database/migrations/Migration -d ./src/shared/database/data-source.ts",
    "migration:create": "pnpm exec tsx $(node -e \"console.log(require.resolve('typeorm/cli.js'))\") migration:create ./src/shared/database/migrations/Migration",
    "migration:run": "pnpm exec tsx $(node -e \"console.log(require.resolve('typeorm/cli.js'))\") migration:run -d ./src/shared/database/data-source.ts",
    "migration:revert": "pnpm exec tsx $(node -e \"console.log(require.resolve('typeorm/cli.js'))\") migration:revert -d ./src/shared/database/data-source.ts"
  },
  "dependencies": {
    "@sao-lourenco/shared": "workspace:*",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.4.0",
    "@swc/core": "^1.10.7",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "unplugin-swc": "^1.5.1",
    "vitest": "^3.0.0"
  }
}
